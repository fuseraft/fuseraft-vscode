{
  "name": "fuseraft",
  "displayName": "fuseraft",
  "description": "Run and manage fuseraft multi-agent orchestrations from VS Code",
  "version": "0.1.28",
  "publisher": "fuseraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fuseraft/fuseraft-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "fuseraft",
    "multi-agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "media/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fuseraft.run",
        "title": "Run Task",
        "category": "fuseraft",
        "icon": "$(play)"
      },
      {
        "command": "fuseraft.runFromConfig",
        "title": "Run Task with This Config",
        "category": "fuseraft",
        "icon": "$(play)"
      },
      {
        "command": "fuseraft.runTaskFile",
        "title": "Run Task File with fuseraft",
        "category": "fuseraft",
        "icon": "$(play)"
      },
      {
        "command": "fuseraft.init",
        "title": "Initialize Config",
        "category": "fuseraft",
        "icon": "$(new-file)"
      },
      {
        "command": "fuseraft.validate",
        "title": "Validate Config",
        "category": "fuseraft",
        "icon": "$(check)"
      },
      {
        "command": "fuseraft.validateDiagram",
        "title": "Validate Config and Show Diagram",
        "category": "fuseraft",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "fuseraft.repl",
        "title": "Open REPL",
        "category": "fuseraft",
        "icon": "$(terminal)"
      },
      {
        "command": "fuseraft.resumeSession",
        "title": "Resume Session",
        "category": "fuseraft",
        "icon": "$(debug-continue)"
      },
      {
        "command": "fuseraft.replResume",
        "title": "Resume REPL Session",
        "category": "fuseraft",
        "icon": "$(history)"
      },
      {
        "command": "fuseraft.deleteSession",
        "title": "Delete Session",
        "category": "fuseraft",
        "icon": "$(trash)"
      },
      {
        "command": "fuseraft.openSessionConfig",
        "title": "Open Session Config",
        "category": "fuseraft",
        "icon": "$(go-to-file)"
      },
      {
        "command": "fuseraft.refreshSessions",
        "title": "Refresh Sessions",
        "category": "fuseraft",
        "icon": "$(refresh)"
      },
      {
        "command": "fuseraft.refreshConfigs",
        "title": "Refresh Configs",
        "category": "fuseraft",
        "icon": "$(refresh)"
      },
      {
        "command": "fuseraft.openConfig",
        "title": "Open Config",
        "category": "fuseraft",
        "icon": "$(go-to-file)"
      },
      {
        "command": "fuseraft.viewSession",
        "title": "View Session Transcript",
        "category": "fuseraft",
        "icon": "$(open-preview)"
      },
      {
        "command": "fuseraft.contextAdd",
        "title": "Add Context",
        "category": "fuseraft",
        "icon": "$(add)"
      },
      {
        "command": "fuseraft.contextRemove",
        "title": "Remove Context Item",
        "category": "fuseraft",
        "icon": "$(trash)"
      },
      {
        "command": "fuseraft.refreshContext",
        "title": "Refresh Context",
        "category": "fuseraft",
        "icon": "$(refresh)"
      },
      {
        "command": "fuseraft.install",
        "title": "Install CLI",
        "category": "fuseraft",
        "icon": "$(cloud-download)"
      },
      {
        "command": "fuseraft.update",
        "title": "Update CLI",
        "category": "fuseraft",
        "icon": "$(sync)"
      },
      {
        "command": "fuseraft.setup",
        "title": "Configure fuseraft",
        "category": "fuseraft",
        "icon": "$(account)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fuseraft",
          "title": "fuseraft",
          "icon": "media/fuseraft.svg"
        }
      ]
    },
    "views": {
      "fuseraft": [
        {
          "id": "fuseraft.taskPanel",
          "name": "Run Task",
          "type": "webview"
        },
        {
          "id": "fuseraft.sessions",
          "name": "Sessions",
          "icon": "$(history)"
        },
        {
          "id": "fuseraft.configs",
          "name": "Configs",
          "icon": "$(settings-gear)"
        },
        {
          "id": "fuseraft.context",
          "name": "Context",
          "icon": "$(book)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "fuseraft.context",
        "contents": "No context items.\n\n[Add Context](command:fuseraft.contextAdd)\n\nContext lets agents reference your files, docs, and specs during a session."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "fuseraft.repl",
          "when": "view == fuseraft.taskPanel",
          "group": "navigation"
        },
        {
          "command": "fuseraft.update",
          "when": "view == fuseraft.taskPanel",
          "group": "navigation"
        },
        {
          "command": "fuseraft.setup",
          "when": "view == fuseraft.taskPanel",
          "group": "navigation"
        },
        {
          "command": "fuseraft.run",
          "when": "view == fuseraft.sessions",
          "group": "navigation"
        },
        {
          "command": "fuseraft.refreshSessions",
          "when": "view == fuseraft.sessions",
          "group": "navigation"
        },
        {
          "command": "fuseraft.init",
          "when": "view == fuseraft.configs",
          "group": "navigation"
        },
        {
          "command": "fuseraft.refreshConfigs",
          "when": "view == fuseraft.configs",
          "group": "navigation"
        },
        {
          "command": "fuseraft.contextAdd",
          "when": "view == fuseraft.context",
          "group": "navigation"
        },
        {
          "command": "fuseraft.refreshContext",
          "when": "view == fuseraft.context",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "fuseraft.resumeSession",
          "when": "view == fuseraft.sessions && viewItem == session-incomplete",
          "group": "inline"
        },
        {
          "command": "fuseraft.resumeSession",
          "when": "view == fuseraft.sessions && viewItem == session-incomplete",
          "group": "1_session"
        },
        {
          "command": "fuseraft.viewSession",
          "when": "view == fuseraft.sessions && (viewItem == session-incomplete || viewItem == session-complete)",
          "group": "inline"
        },
        {
          "command": "fuseraft.viewSession",
          "when": "view == fuseraft.sessions && (viewItem == session-incomplete || viewItem == session-complete)",
          "group": "1_session"
        },
        {
          "command": "fuseraft.openSessionConfig",
          "when": "view == fuseraft.sessions && (viewItem == session-incomplete || viewItem == session-complete)",
          "group": "1_session"
        },
        {
          "command": "fuseraft.deleteSession",
          "when": "view == fuseraft.sessions && (viewItem == session-incomplete || viewItem == session-complete)",
          "group": "2_danger"
        },
        {
          "command": "fuseraft.runFromConfig",
          "when": "view == fuseraft.configs && viewItem == config",
          "group": "inline"
        },
        {
          "command": "fuseraft.runFromConfig",
          "when": "view == fuseraft.configs && viewItem == config",
          "group": "1_config"
        },
        {
          "command": "fuseraft.validate",
          "when": "view == fuseraft.configs && viewItem == config",
          "group": "1_config"
        },
        {
          "command": "fuseraft.validateDiagram",
          "when": "view == fuseraft.configs && viewItem == config",
          "group": "1_config"
        },
        {
          "command": "fuseraft.openConfig",
          "when": "view == fuseraft.configs && viewItem == config",
          "group": "1_config"
        },
        {
          "command": "fuseraft.contextRemove",
          "when": "view == fuseraft.context && viewItem == contextItem",
          "group": "inline"
        },
        {
          "command": "fuseraft.contextRemove",
          "when": "view == fuseraft.context && viewItem == contextItem",
          "group": "1_context"
        }
      ],
      "editor/context": [
        {
          "command": "fuseraft.runFromConfig",
          "when": "fuseraft.isFuseraftConfig",
          "group": "fuseraft@1"
        },
        {
          "command": "fuseraft.validate",
          "when": "fuseraft.isFuseraftConfig",
          "group": "fuseraft@2"
        },
        {
          "command": "fuseraft.validateDiagram",
          "when": "fuseraft.isFuseraftConfig",
          "group": "fuseraft@3"
        },
        {
          "command": "fuseraft.runTaskFile",
          "when": "resourceExtname =~ /\\.(md|txt)/",
          "group": "fuseraft@1"
        }
      ],
      "explorer/context": [
        {
          "command": "fuseraft.runFromConfig",
          "when": "resourceExtname =~ /\\.(yaml|yml|json)/ && resourceFilename =~ /orchestration|fuseraft/",
          "group": "fuseraft@1"
        },
        {
          "command": "fuseraft.validate",
          "when": "resourceExtname =~ /\\.(yaml|yml|json)/ && resourceFilename =~ /orchestration|fuseraft/",
          "group": "fuseraft@2"
        },
        {
          "command": "fuseraft.validateDiagram",
          "when": "resourceExtname =~ /\\.(yaml|yml|json)/ && resourceFilename =~ /orchestration|fuseraft/",
          "group": "fuseraft@3"
        },
        {
          "command": "fuseraft.runTaskFile",
          "when": "resourceExtname =~ /\\.(md|txt)/",
          "group": "fuseraft@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "fuseraft.runTaskFile",
          "when": "resourceExtname =~ /\\.(md|txt)/",
          "group": "fuseraft@1"
        }
      ]
    },
    "configuration": {
      "title": "fuseraft",
      "properties": {
        "fuseraft.binaryPath": {
          "type": "string",
          "default": "fuseraft",
          "description": "Path to the fuseraft binary. Defaults to 'fuseraft' (must be on PATH). Set to an absolute path if needed."
        },
        "fuseraft.defaultConfigPath": {
          "type": "string",
          "default": "",
          "description": "Default config path relative to the workspace root (e.g. '.fuseraft/config/orchestration.yaml'). Leave blank to be prompted."
        },
        "fuseraft.runFlags": {
          "type": "string",
          "default": "",
          "description": "Additional flags to pass to 'fuseraft run' (e.g. '--tools --verbose')."
        },
        "fuseraft.openTerminalOnRun": {
          "type": "boolean",
          "default": true,
          "description": "Open and focus the integrated terminal when running a task."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "**/orchestration.json",
          "**/*.fuseraft.json"
        ],
        "url": "./schemas/fuseraft-config.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
